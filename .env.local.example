# ─────────────────────────────────────────────────────────────────────────────
# Stella Avatar Frontend — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit your actual .env.local file.
# ─────────────────────────────────────────────────────────────────────────────

# ── LiveKit ───────────────────────────────────────────────────────────────────
# Same project as the backend — used to connect the browser to the voice room
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
NEXT_PUBLIC_LIVEKIT_TOKEN_URL=http://localhost:8081/token

# ── Backend API URL ───────────────────────────────────────────────────────────
# Points to the running FastAPI backend (main.py)
NEXT_PUBLIC_API_URL=http://localhost:8000
